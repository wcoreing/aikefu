# -----------------------------
# qiwei-server 环境变量示例
# 复制为 .env 后按需修改
# -----------------------------

# ===== 企微回调（微信客服）=====
# 回调验签 Token（企微后台“接收消息”配置一致）
WECOM_TOKEN=your_wecom_token

# EncodingAESKey（企微后台“接收消息”配置一致）
WECOM_ENCODING_AES_KEY=your_encoding_aes_key

# 企业 CorpID（作 ReceiveId）
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxxxx

# 可调用“微信客服 API”的应用 Secret（需在客服后台授权）
WECOM_CORP_SECRET=your_corp_secret

# （可选但推荐）客户联系 Secret：用于 externalcontact/get 获取客户名称/备注等
# 不填会回落用 WECOM_CORP_SECRET（但要求该 Secret 具备客户联系权限）
# WECOM_CONTACT_SECRET=your_contact_secret


# ===== 百炼（DashScope / Model Studio）=====
# 百炼 API Key
DASHSCOPE_API_KEY=sk-xxxx

# 百炼应用 APP_ID（工作流应用或智能体应用）
BAILIAN_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 调用模式：workflow / agent
BAILIAN_INVOKE_MODE=workflow

# 工作流开始节点参数映射（只有当你的画布参数名不是默认值时才需要改）
# - query_key：开始节点里“用户问题”的参数名（很多画布是 query；也可能直接用 prompt）
# - user_key：开始节点里 external_userid 的参数名（常见 external_userid）
# - open_kfid_key：开始节点里 open_kfid 的参数名（常见 open_kfid）
# - summary_key：开始节点里 summary 的参数名（常见 summary）
# - session_key：开始节点里会话参数名（如 session_id；不配置则不传）
BAILIAN_WORKFLOW_QUERY_KEY=query
BAILIAN_WORKFLOW_USER_KEY=external_userid
BAILIAN_WORKFLOW_OPEN_KFID_KEY=open_kfid
BAILIAN_WORKFLOW_SUMMARY_KEY=summary
# BAILIAN_WORKFLOW_SESSION_KEY=session_id


# ===== Redis（强烈建议生产开启）=====
# 用于 cursor / msg 去重 / session 持久化，避免重启导致历史重放
REDIS_URL=redis://127.0.0.1:6379/0


# ===== 内部通知（高意向通知销售/客服）=====
# 自建应用 AgentId（整数），用于 /cgi-bin/message/send 给企业成员发通知
WECOM_AGENT_ID=1000002

# 接收通知的成员 userid，多个用 | 分隔
WECOM_NOTIFY_TOUSER=userid1|userid2


# ===== 转人工（可选）=====
# 配置则转入指定接待人（service_state=3）；不配则进入待接入池（service_state=2）
# WECOM_KF_DEFAULT_SERVICER_USERID=zhangsan


# ===== MCP 服务（给百炼工作流调用工具）=====
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=9999
MCP_PATH=/mcp
MCP_JSON_RESPONSE=true
MCP_STATELESS_HTTP=true


# ===== 群发（可选）=====
# WECOM_DEFAULT_OPEN_KFID=wkxxxxxxxxxxxxxxxxxx
# WECOM_GROUP_FOLLOW_USERIDS=userid1,userid2
# BAILIAN_GROUP_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ===== 内部接口（可选）=====
# INTERNAL_API_TOKEN=your_internal_token

